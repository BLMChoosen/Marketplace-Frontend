# ──────────────────────────────────────────
# Marketplace Frontend — Public Runtime Env
# Copy this file to .env.local and fill in values.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ──────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=http://localhost
NEXT_PUBLIC_CDN_URL=

# Container port (compose only)
FRONTEND_PORT=3000
