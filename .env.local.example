# ──────────────────────────────────────────
# Marketplace Frontend — Public Runtime Env
# Copy this file to .env.local and fill in values.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ──────────────────────────────────────────

# Empty means same-origin through Nginx (/api and /socket.io).
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_SITE_URL=https://marketplace.example.com

# Container port (compose only)
FRONTEND_PORT=3000
